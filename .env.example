# Environment variables (sample)

# Google Generative AI API key (server-side only)
GOOGLE_API_KEY=

# Optional: alternate env name if you prefer
# GEMINI_API_KEY=

# Privacy-first analytics (self-hosted Plausible)
NEXT_PUBLIC_ENABLE_PLAUSIBLE=true
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=elkaza.org
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_SRC=https://analytics.elkaza.at/js/script.js
